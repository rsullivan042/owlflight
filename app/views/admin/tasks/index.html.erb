<div class="flex flex-col">
  <%= link_to new_admin_project_task_path(@project), class: "flex flex-row text-amber-400 mb-4" do %>
    <%= image_tag "icons/square-plus.svg", class: "mr-1" %>
    Create Task
  <% end %>
  <ul class="space-y-1">
    <% @project.tasks.each do |task| %>
      <li class="flex items-center gap-3">
        <span class="w-5 text-center">
          <% if task.completed? %>
            <%= image_tag "icons/check.svg", class: "w-4 h-4 inline" %>
          <% else %>
            -
          <% end %>
        </span>

        <span class="w-100">
          <%= task.description %>
        </span>

        <span class="flex flex-row space-x-2">
          <%= link_to edit_admin_project_task_path(@project, task) do %>
            <%= image_tag "icons/square-pen.svg" %>
          <% end %>

          <%= link_to admin_project_task_path(@project, task), data: { turbo_method: :delete, turbo_confirm: "Delete this task?" } do %>
            <%= image_tag "icons/trash.svg" %>
          <% end %>
        </span>
      </li>
    <% end %>
  </ul>
</div>
